# CrowByte Terminal — Environment Configuration
# Copy this to .env and fill in your values.

# ─── Supabase ─────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_SUPABASE_SERVICE_KEY=your-service-role-key
VITE_SUPABASE_PROJECT_REF=your-project-ref

# ─── OpenClaw VPS ─────────────────────────────────────────────────────────────
VITE_OPENCLAW_HOST=your-vps-ip
VITE_OPENCLAW_HOSTNAME=your-vps-hostname.example.com
VITE_VPS_IP=your-vps-ip
VITE_VPS_HOSTNAME_ID=your-vps-hostname-id
VITE_OPENCLAW_GATEWAY_PASSWORD=your-gateway-password
VITE_OPENCLAW_GATEWAY_TOKEN=your-gateway-token
VITE_OPENCLAW_SSH_PASSWORD=your-ssh-password
VITE_NVIDIA_API_KEY=your-nvidia-api-key
VITE_NVIDIA_PROXY_PORT=19990

# ─── VNC Remote Control ──────────────────────────────────────────────────────
VITE_VNC_WS_URL=wss://your-vps:18790
VITE_VNC_PASSWORD=your-vnc-password

# ─── Tavily Search ───────────────────────────────────────────────────────────
VITE_TAVILY_API_KEY=your-tavily-key
TAVILY_API_KEY=your-tavily-key

# ─── External APIs ───────────────────────────────────────────────────────────
VITE_SHODAN_API_KEY=your-shodan-key
VITE_NVD_API_KEY=your-nvd-key
VITE_VENICE_API_KEY=your-venice-key

# ─── MCP Cloud (Optional) ──────────────────────────────────────────────────
VITE_MCP_CLOUD_URL=
VITE_MCP_CLOUD_AUTH=

# ─── Docker / Container Settings ────────────────────────────────────────────
# VNC_PASSWORD=
# NOVNC_PORT=6080
# RESOLUTION=1920x1080x24
