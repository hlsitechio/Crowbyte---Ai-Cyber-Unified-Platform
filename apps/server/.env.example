# CrowByte Server Configuration

# Server
PORT=3000

# Auth (change these in production!)
CROWBYTE_USER=admin
CROWBYTE_PASS=crowbyte
# Or use pre-hashed password (bcrypt):
# CROWBYTE_PASS_HASH=$2b$12$...

# JWT secret (auto-generated if not set)
# JWT_SECRET=your-secret-here

# CORS (default: allow all)
# CORS_ORIGIN=https://yourdomain.com

# SSL (optional — omit for HTTP)
# SSL_CERT=/path/to/fullchain.pem
# SSL_KEY=/path/to/privkey.pem

# Environment
NODE_ENV=production
